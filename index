                            </div>
                            <p class="text-gray-400 text-sm">Click to Preview</p>
                        </div>
                    </div>
                    
                    <!-- Simulated Video Overlay -->
                    <div id="video-overlay" class="absolute inset-0 bg-gradient-to-br from-indigo-900/50 to-purple-900/50 opacity-0 pointer-events-none transition-opacity">
                        <div class="absolute inset-0 flex items-center justify-center">
                            <div class="text-center">
                                <div class="text-6xl mb-4">🎬</div>
                                <h3 class="text-2xl font-bold mb-2">Cinematic Preview</h3>
                                <p class="text-gray-300">Scene transitions active</p>
                            </div>
                        </div>
                    </div>

                    <!-- Subtitle Preview -->
                    <div class="absolute bottom-16 left-0 right-0 text-center px-4">
                        <p id="subtitle-preview" class="text-white text-lg font-medium drop-shadow-lg bg-black/40 inline-block px-4 py-2 rounded-lg backdrop-blur-sm sinhala-text hidden">
                            සිංහල උපසිරසි මෙහි දිස් වේ
                        </p>
                    </div>

                    <!-- Controls -->
                    <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/80 to-transparent p-4">
                        <div class="flex items-center gap-4">
                            <button onclick="playVideo()" class="text-white hover:text-indigo-400 transition-colors">
                                <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></button>
                            </button>
                            <div class="flex-1 h-1 bg-white/20 rounded-full overflow-hidden cursor-pointer">
                                <div id="progress-bar" class="h-full bg-indigo-500 w-0 transition-all duration-300"></div>
                            </div>
