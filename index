<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Lakiya AI - Cinematic Video Generation</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Space+Grotesk:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary-glow: rgba(99, 102, 241, 0.5);
            --secondary-glow: rgba(168, 85, 247, 0.3);
            --accent-cyan: rgba(34, 211, 238, 0.6);
        }
        
        body {
            font-family: 'Inter', sans-serif;
            background: #000000;
            overflow-x: hidden;
        }
        
        .font-display {
            font-family: 'Space Grotesk', sans-serif;
        }
        
        /* Animated Background Canvas */
        #bg-canvas {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: -1;
            opacity: 0.6;
        }
        
        /* Glassmorphism Utilities */
        .glass {
            background: rgba(255, 255, 255, 0.03);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.37);
        }
        
        .glass-strong {
            background: rgba(20, 20, 25, 0.7);
            backdrop-filter: blur(30px);
            -webkit-backdrop-filter: blur(30px);
            border: 1px solid rgba(255, 255, 255, 0.15);
            box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.5), 
                        inset 0 1px 0 rgba(255, 255, 255, 0.1);
        }
        
        .glass-card {
            background: linear-gradient(135deg, rgba(255,255,255,0.05) 0%, rgba(255,255,255,0.01) 100%);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.08);
            transition: all 0.3s ease;
        }
        
        .glass-card:hover {
            background: linear-gradient(135deg, rgba(255,255,255,0.08) 0%, rgba(255,255,255,0.03) 100%);
            border-color: rgba(255, 255, 255, 0.15);
            transform: translateY(-2px);
        }
        
        /* Gradient Text */
        .gradient-text {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 50%, #f093fb 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        
        .gradient-text-cyan {
            background: linear-gradient(135deg, #22d3ee 0%, #818cf8 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        
        /* Glow Effects */
        .glow-button {
            position: relative;
            overflow: hidden;
            transition: all 0.3s ease;
        }
        
        .glow-button::before {
            content: '';
            position: absolute;
            top: -2px;
            left: -2px;
            right: -2px;
            bottom: -2px;
            background: linear-gradient(45deg, #6366f1, #a855f7, #22d3ee, #6366f1);
            background-size: 400%;
            z-index: -1;
            animation: glow 20s linear infinite;
            border-radius: inherit;
            opacity: 0;
            transition: opacity 0.3s ease;
        }
        
        .glow-button:hover::before {
            opacity: 1;
        }
        
        @keyframes glow {
            0% { background-position: 0 0; }
            50% { background-position: 400% 0; }
            100% { background-position: 0 0; }
        }
        
        /* Progress Animation */
        .progress-ring {
            transform: rotate(-90deg);
            transform-origin: 50% 50%;
        }
        
        .progress-ring-circle {
            transition: stroke-dashoffset 0.35s;
            transform-origin: 50% 50%;
        }
        
        /* Typing Cursor */
        .typing-cursor::after {
            content: '|';
            animation: blink 1s infinite;
            color: #22d3ee;
        }
        
        @keyframes blink {
            0%, 50% { opacity: 1; }
            51%, 100% { opacity: 0; }
        }
        
        /* Particle Animation */
        .particle {
            position: absolute;
            width: 4px;
            height: 4px;
            background: rgba(99, 102, 241, 0.6);
            border-radius: 50%;
            pointer-events: none;
            animation: float 10s infinite ease-in-out;
        }
        
        @keyframes float {
            0%, 100% { transform: translateY(0) translateX(0); opacity: 0; }
            10% { opacity: 1; }
            90% { opacity: 1; }
            100% { transform: translateY(-100vh) translateX(50px); opacity: 0; }
        }
        
        /* Scene Cards */
        .scene-card {
            opacity: 0;
            transform: translateY(20px);
            animation: slideIn 0.5s forwards;
        }
        
        @keyframes slideIn {
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
        
        /* Custom Scrollbar */
        ::-webkit-scrollbar {
            width: 8px;
        }
        
        ::-webkit-scrollbar-track {
            background: rgba(0,0,0,0.3);
        }
        
        ::-webkit-scrollbar-thumb {
            background: rgba(99, 102, 241, 0.5);
            border-radius: 4px;
        }
        
        ::-webkit-scrollbar-thumb:hover {
            background: rgba(99, 102, 241, 0.8);
        }
        
        /* Neural Network Animation */
        .neural-line {
            stroke-dasharray: 1000;
            stroke-dashoffset: 1000;
            animation: drawLine 2s forwards;
        }
        
        @keyframes drawLine {
            to { stroke-dashoffset: 0; }
        }
        
        /* Sinhala Font Support */
        .sinhala-text {
            font-family: 'Noto Sans Sinhala', 'Inter', sans-serif;
        }
        
        /* Toggle Switch */
        .toggle-checkbox:checked {
            right: 0;
            border-color: #6366f1;
        }
        
        .toggle-checkbox:checked + .toggle-label {
            background-color: #6366f1;
        }
        
        /* Pulse Animation */
        .pulse-ring {
            position: absolute;
            border-radius: 50%;
            border: 2px solid rgba(99, 102, 241, 0.5);
            animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
        }
        
        @keyframes pulse {
            0%, 100% { transform: scale(1); opacity: 1; }
            50% { transform: scale(1.5); opacity: 0; }
        }
        
        /* Video Player Simulation */
        .video-frame {
            background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
            position: relative;
            overflow: hidden;
        }
        
        .video-frame::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100"><rect width="100" height="100" fill="none" stroke="rgba(99,102,241,0.1)" stroke-width="0.5"/></svg>');
            background-size: 20px 20px;
            opacity: 0.3;
        }
        
        /* Range Slider */
        input[type=range] {
            -webkit-appearance: none;
            background: transparent;
        }
        
        input[type=range]::-webkit-slider-thumb {
            -webkit-appearance: none;
            height: 16px;
            width: 16px;
            border-radius: 50%;
            background: #6366f1;
            cursor: pointer;
            margin-top: -6px;
            box-shadow: 0 0 10px rgba(99, 102, 241, 0.5);
        }
        
        input[type=range]::-webkit-slider-runnable-track {
            width: 100%;
            height: 4px;
            cursor: pointer;
            background: rgba(255,255,255,0.1);
            border-radius: 2px;
        }
    </style>
</head>
<body class="text-white antialiased">

    <!-- Animated Background -->
    <canvas id="bg-canvas"></canvas>
    
    <!-- Floating Particles Container -->
    <div id="particles" class="fixed inset-0 pointer-events-none z-0"></div>

    <!-- Navigation -->
    <nav class="fixed top-0 w-full z-50 glass-strong border-b border-white/10">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex items-center justify-between h-16">
                <div class="flex items-center gap-3">
                    <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-indigo-500 to-purple-600 flex items-center justify-center font-bold text-white font-display text-lg">L</div>
                    <span class="font-display text-xl font-bold tracking-tight">Lakiya<span class="gradient-text"> AI</span></span>
                </div>
                
                <div class="hidden md:flex items-center gap-8">
                    <a href="#features" class="text-sm text-gray-300 hover:text-white transition-colors">Features</a>
                    <a href="#how-it-works" class="text-sm text-gray-300 hover:text-white transition-colors">How it Works</a>
                    <a href="#pricing" class="text-sm text-gray-300 hover:text-white transition-colors">Pricing</a>
                    <div class="flex items-center gap-2 px-3 py-1 rounded-full glass text-xs">
                        <span class="w-2 h-2 bg-green-400 rounded-full animate-pulse"></span>
                        <span class="text-gray-300">System Online</span>
                    </div>
                </div>

                <div class="flex items-center gap-4">
                    <button onclick="toggleLanguage()" class="flex items-center gap-2 px-4 py-2 rounded-lg glass hover:bg-white/5 transition-all text-sm">
                        <span id="lang-indicator">🇺🇸 EN</span>
                    </button>
                    <button class="px-4 py-2 rounded-lg bg-white/10 hover:bg-white/20 transition-all text-sm font-medium border border-white/20">
                        Sign In
                    </button>
                </div>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <main class="relative z-10 pt-24 pb-12 px-4 sm:px-6 lg:px-8 max-w-7xl mx-auto">
        
        <!-- Hero Section -->
        <div class="text-center mb-16 relative">
            <div class="absolute inset-0 -z-10">
                <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-indigo-600/20 rounded-full blur-[120px]"></div>
            </div>
            
            <h1 class="font-display text-5xl md:text-7xl font-bold mb-6 leading-tight">
                <span class="block text-gray-400 text-2xl md:text-3xl font-normal mb-2 tracking-widest uppercase">Cinematic AI Video Generation</span>
                <span id="hero-title" class="gradient-text typing-cursor">Create Magic with Words</span>
            </h1>
            
            <p class="text-gray-400 text-lg md:text-xl max-w-2xl mx-auto mb-8 leading-relaxed" id="hero-subtitle">
                Transform simple prompts into 10-minute HD cinematic videos. AI-powered script expansion, automatic scene generation, and natural Sinhala voiceovers.
            </p>

            <!-- Language Badge -->
            <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full glass mb-8">
                <span class="flex items-center gap-1">
                    <span class="w-2 h-2 bg-cyan-400 rounded-full"></span>
                    <span class="text-sm text-cyan-400 font-medium">සිංහල</span>
                </span>
                <span class="text-gray-500">|</span>
                <span class="text-sm text-gray-300">Natural Voice Support</span>
            </div>
        </div>

        <!-- Main Input Interface -->
        <div class="max-w-3xl mx-auto mb-16 relative">
            <div class="glass-strong rounded-2xl p-1 shadow-2xl shadow-indigo-500/20">
                <div class="bg-black/40 rounded-xl p-6 md:p-8">
                    <div class="relative">
                        <textarea 
                            id="prompt-input" 
                            class="w-full bg-transparent text-white text-lg md:text-xl placeholder-gray-600 border-none resize-none focus:outline-none focus:ring-0 min-h-[120px] font-light leading-relaxed"
                            placeholder="Describe your video idea... (e.g., 'A serene meditation journey through ancient Sri Lankan temples at sunrise')"
                        ></textarea>
                        
                        <!-- AI Enhancement Indicator -->
                        <div id="ai-enhance-badge" class="absolute bottom-4 right-4 hidden items-center gap-2 px-3 py-1 rounded-full bg-indigo-500/20 border border-indigo-500/30 text-xs text-indigo-300">
                            <svg class="w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24">
                                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                            </svg>
                            <span>AI Enhancing Prompt...</span>
                        </div>
                    </div>

                    <!-- Quick Settings Bar -->
                    <div class="flex flex-wrap items-center justify-between gap-4 mt-6 pt-6 border-t border-white/10">
                        <div class="flex items-center gap-4 flex-wrap">
                            <!-- Duration -->
                            <div class="flex items-center gap-2">
                                <span class="text-xs text-gray-500 uppercase tracking-wider">Duration</span>
                                <select id="duration-select" class="bg-white/5 border border-white/10 rounded-lg px-3 py-1.5 text-sm text-white focus:outline-none focus:border-indigo-500">
                                    <option value="1">1 min</option>
                                    <option value="3">3 min</option>
                                    <option value="5" selected>5 min</option>
                                    <option value="10">10 min</option>
                                </select>
                            </div>

                            <!-- Resolution -->
                            <div class="flex items-center gap-2">
                                <span class="text-xs text-gray-500 uppercase tracking-wider">Quality</span>
                                <select id="quality-select" class="bg-white/5 border border-white/10 rounded-lg px-3 py-1.5 text-sm text-white focus:outline-none focus:border-indigo-500">
                                    <option value="720">720p</option>
                                    <option value="1080" selected>1080p HD</option>
                                    <option value="4k">4K</option>
                                </select>
                            </div>

                            <!-- Voice -->
                            <div class="flex items-center gap-2">
                                <span class="text-xs text-gray-500 uppercase tracking-wider">Voice</span>
                                <select id="voice-select" class="bg-white/5 border border-white/10 rounded-lg px-3 py-1.5 text-sm text-white focus:outline-none focus:border-indigo-500">
                                    <option value="auto">Auto Detect</option>
                                    <option value="sinhala-female">සිංහල - Female</option>
                                    <option value="sinhala-male">සිංහල - Male</option>
                                    <option value="english-female">English - Female</option>
                                    <option value="english-male">English - Male</option>
                                </select>
                            </div>
                        </div>

                        <div class="flex items-center gap-2">
                            <button onclick="clearPrompt()" class="p-2 rounded-lg hover:bg-white/5 text-gray-400 hover:text-white transition-all" title="Clear">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                            </button>
                        </div>
                    </div>
                </div>

                <!-- Generate Button -->
                <div class="p-4 bg-gradient-to-r from-indigo-600/20 to-purple-600/20 rounded-b-xl">
                    <button onclick="generateVideo()" id="generate-btn" class="w-full glow-button bg-gradient-to-r from-indigo-600 to-purple-600 hover:from-indigo-500 hover:to-purple-500 text-white font-semibold py-4 px-8 rounded-xl text-lg shadow-lg shadow-indigo-500/25 transition-all transform hover:scale-[1.02] active:scale-[0.98] flex items-center justify-center gap-3">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
                        <span>Generate Magic</span>
                    </button>
                </div>
            </div>

            <!-- Enhanced Prompt Preview -->
            <div id="enhanced-preview" class="hidden mt-6 glass rounded-xl p-6 border-l-4 border-indigo-500">
                <div class="flex items-center gap-2 mb-3">
                    <svg class="w-5 h-5 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
                    <span class="text-sm font-semibold text-indigo-400 uppercase tracking-wider">AI Enhanced Cinematic Script</span>
                </div>
                <p id="enhanced-text" class="text-gray-300 text-sm leading-relaxed italic"></p>
            </div>
        </div>

        <!-- Generation Progress Section (Hidden by default) -->
        <div id="generation-section" class="hidden max-w-4xl mx-auto mb-16">
            <div class="glass-strong rounded-2xl p-8 relative overflow-hidden">
                <!-- Progress Header -->
                <div class="flex items-center justify-between mb-8">
                    <div>
                        <h3 class="text-2xl font-display font-bold mb-1">Generating Your Cinematic Experience</h3>
                        <p class="text-gray-400 text-sm">AI is crafting scenes, synthesizing audio, and rendering video</p>
                    </div>
                    <div class="relative w-16 h-16">
                        <svg class="progress-ring w-16 h-16" viewBox="0 0 100 100">
                            <circle class="text-gray-700" stroke-width="8" stroke="currentColor" fill="transparent" r="42" cx="50" cy="50"/>
                            <circle id="progress-circle" class="progress-ring-circle text-indigo-500" stroke-width="8" stroke-linecap="round" stroke="currentColor" fill="transparent" r="42" cx="50" cy="50" stroke-dasharray="264" stroke-dashoffset="264"/>
                        </svg>
                        <span id="progress-text" class="absolute inset-0 flex items-center justify-center text-sm font-bold">0%</span>
                    </div>
                </div>

                <!-- Generation Steps -->
                <div class="space-y-4" id="generation-steps">
                    <div class="step-item flex items-center gap-4 p-4 rounded-lg bg-white/5 border border-white/5 opacity-50" data-step="1">
                        <div class="w-8 h-8 rounded-full bg-indigo-500/20 flex items-center justify-center">
                            <span class="text-xs font-bold">1</span>
                        </div>
                        <div class="flex-1">
                            <h4 class="font-medium text-sm">Script Expansion & Analysis</h4>
                            <p class="text-xs text-gray-500">Enhancing prompt with cinematic details</p>
                        </div>
                        <div class="step-status w-2 h-2 rounded-full bg-gray-600"></div>
                    </div>

                    <div class="step-item flex items-center gap-4 p-4 rounded-lg bg-white/5 border border-white/5 opacity-50" data-step="2">
                        <div class="w-8 h-8 rounded-full bg-indigo-500/20 flex items-center justify-center">
                            <span class="text-xs font-bold">2</span>
                        </div>
                        <div class="flex-1">
                            <h4 class="font-medium text-sm">Scene Generation & Storyboarding</h4>
                            <p class="text-xs text-gray-500">Creating visual sequences with AI cinematography</p>
                        </div>
                        <div class="step-status w-2 h-2 rounded-full bg-gray-600"></div>
                    </div>

                    <div class="step-item flex items-center gap-4 p-4 rounded-lg bg-white/5 border border-white/5 opacity-50" data-step="3">
                        <div class="w-8 h-8 rounded-full bg-indigo-500/20 flex items-center justify-center">
                            <span class="text-xs font-bold">3</span>
                        </div>
                        <div class="flex-1">
                            <h4 class="font-medium text-sm">Voice Synthesis & Audio Design</h4>
                            <p class="text-xs text-gray-500">Natural Sinhala TTS with emotional matching</p>
                        </div>
                        <div class="step-status w-2 h-2 rounded-full bg-gray-600"></div>
                    </div>

                    <div class="step-item flex items-center gap-4 p-4 rounded-lg bg-white/5 border border-white/5 opacity-50" data-step="4">
                        <div class="w-8 h-8 rounded-full bg-indigo-500/20 flex items-center justify-center">
                            <span class="text-xs font-bold">4</span>
                        </div>
                        <div class="flex-1">
                            <h4 class="font-medium text-sm">Video Composition & Rendering</h4>
                            <p class="text-xs text-gray-500">Final assembly with transitions and effects</p>
                        </div>
                        <div class="step-status w-2 h-2 rounded-full bg-gray-600"></div>
                    </div>
                </div>

                <!-- Scene Preview Grid -->
                <div id="scene-preview" class="hidden mt-8 grid grid-cols-2 md:grid-cols-4 gap-4">
                    <!-- Scenes will be generated here -->
                </div>
            </div>
        </div>

        <!-- Video Player Section (Hidden by default) -->
        <div id="video-section" class="hidden max-w-5xl mx-auto mb-16">
            <div class="glass-strong rounded-2xl overflow-hidden shadow-2xl shadow-indigo-500/20">
                <!-- Video Header -->
                <div class="flex items-center justify-between p-4 border-b border-white/10 bg-white/5">
                    <div class="flex items-center gap-3">
                        <div class="w-3 h-3 rounded-full bg-red-500"></div>
                        <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
                        <div class="w-3 h-3 rounded-full bg-green-500"></div>
                        <span class="ml-4 text-sm text-gray-400 font-mono">lakiya_generated_cinematic.mp4</span>
                    </div>
                    <div class="flex items-center gap-2">
                        <span class="text-xs text-gray-500 px-2 py-1 rounded bg-white/5">1080p</span>
