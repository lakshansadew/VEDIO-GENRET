    <script>
        // Three.js Background Animation
        const canvas = document.getElementById('bg-canvas');
        const scene = new THREE.Scene();
        const camera = new THREE.PerspectiveCamera(75, window.innerWidth / window.innerHeight, 0.1, 1000);
        const renderer = new THREE.WebGLRenderer({ canvas: canvas, alpha: true });
        
        renderer.setSize(window.innerWidth, window.innerHeight);
        renderer.setPixelRatio(window.devicePixelRatio);
        
        // Create particles
        const particlesGeometry = new THREE.BufferGeometry();
        const particlesCount = 1500;
        const posArray = new Float32Array(particlesCount * 3);
        
        for(let i = 0; i < particlesCount * 3; i++) {
            posArray[i] = (Math.random() - 0.5) * 50;
        }
        
        particlesGeometry.setAttribute('position', new THREE.BufferAttribute(posArray, 3));
        
        const particlesMaterial = new THREE.PointsMaterial({
            size: 0.02,
            color: 0x6366f1,
            transparent: true,
            opacity: 0.6,
            blending: THREE.AdditiveBlending
        });
        
        const particlesMesh = new THREE.Points(particlesGeometry, particlesMaterial);
        scene.add(particlesMesh);
        
        camera.position.z = 5;
        
        // Mouse interaction
        let mouseX = 0;
        let mouseY = 0;
        
        document.addEventListener('mousemove', (event) => {
            mouseX = event.clientX / window.innerWidth - 0.5;
            mouseY = event.clientY / window.innerHeight - 0.5;
        });
        
        // Animation loop
        const animate = () => {
            requestAnimationFrame(animate);
            
            particlesMesh.rotation.y += 0.001;
            particlesMesh.rotation.x += 0.0005;
            
            // Subtle mouse follow
            particlesMesh.rotation.x += mouseY * 0.05;
            particlesMesh.rotation.y += mouseX * 0.05;
            
            renderer.render(scene, camera);
        };
        
        animate();
        
        // Handle resize
        window.addEventListener('resize', () => {
            camera.aspect = window.innerWidth / window.innerHeight;
            camera.updateProjectionMatrix();
            renderer.setSize(window.innerWidth, window.innerHeight);
        });
        
        // Floating particles HTML overlay
        function createParticles() {
            const container = document.getElementById('particles');
            for (let i = 0; i < 20; i++) {
                const particle = document.createElement('div');
                particle.className = 'particle';
                particle.style.left = Math.random() * 100 + '%';
                particle.style.animationDelay = Math.random() * 10 + 's';
                particle.style.animationDuration = (Math.random() * 10 + 10) + 's';
                container.appendChild(particle);
            }
        }
        createParticles();
        
        // Typing effect for hero
        const phrases = ['Create Magic with Words', 'Generate Cinematic Stories', 'මැජික් සෑදීම', 'AI-Powered Creation'];
        let phraseIndex = 0;
        let charIndex = 0;
        let isDeleting = false;
        const heroTitle = document.getElementById('hero-title');
        
        function typeEffect() {
            const currentPhrase = phrases[phraseIndex];
            
            if (isDeleting) {
                heroTitle.textContent = currentPhrase.substring(0, charIndex - 1);
                charIndex--;
            } else {
                heroTitle.textContent = currentPhrase.substring(0, charIndex + 1);
                charIndex++;
            }
            
            let typeSpeed = isDeleting ? 50 : 100;
            
            if (!isDeleting && charIndex === currentPhrase.length) {
                typeSpeed = 2000;
                isDeleting = true;
            } else if (isDeleting && charIndex === 0) {
                isDeleting = false;
                phraseIndex = (phraseIndex + 1) % phrases.length;
                typeSpeed = 500;
            }
            
            setTimeout(typeEffect, typeSpeed);
        }
        
        // Start typing effect
        setTimeout(typeEffect, 1000);
        
        // Language Toggle
        let currentLang = 'en';
        function toggleLanguage() {
            currentLang = currentLang === 'en' ? 'si' : 'en';
            const indicator = document.getElementById('lang-indicator');
            const subtitle = document.getElementById('hero-subtitle');
            const input = document.getElementById('prompt-input');
            
            if (currentLang === 'si') {
                indicator.textContent = '🇱🇰 සිං';
                subtitle.textContent = 'සරල ප්‍රොම්ප්ට් 10 මිනිත්තු HD සිනමාතමක වීඩියෝ බවට පරිවර්තනය කරන්න. AI බලගතු ස්ක්‍රිප්ට් විස්තාරණය, ස්වයංක්‍රීය දර්ශන උත්පාදනය, සහ ස්වාභාවික සිංහල voiceovers.';
                input.placeholder = 'ඔබේ වීඩියෝ අදහස විස්තර කරන්න... (උදා: 'පුරාණ ශ්‍රී ලංකානු දේවාල වලින් සුවිසල් සුරඟන චාරිකාව')";
            } else {
                indicator.textContent = '🇺🇸 EN';
                subtitle.textContent = 'Transform simple prompts into 10-minute HD cinematic videos. AI-powered script expansion, automatic scene generation, and natural Sinhala voiceovers.';
                input.placeholder = "Describe your video idea... (e.g., 'A serene meditation journey through ancient Sri Lankan temples at sunrise')";
            }
        }
        
        // Clear prompt
        function clearPrompt() {
            document.getElementById('prompt-input').value = '';
            document.getElementById('enhanced-preview').classList.add('hidden');
        }
        
        // Generate Video Function
        async function generateVideo() {
            const prompt = document.getElementById('prompt-input').value;
            if (!prompt.trim()) {
                alert('Please enter a prompt first');
                return;
            }
            
            const btn = document.getElementById('generate-btn');
            const originalText = btn.innerHTML;
            btn.innerHTML = '<svg class="w-6 h-6 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg><span>Initializing...</span>';
            btn.disabled = true;
            
            // Show generation section
            document.getElementById('generation-section').classList.remove('hidden');
            document.getElementById('video-section').classList.add('hidden');
            
            // Scroll to generation section
            document.getElementById('generation-section').scrollIntoView({ behavior: 'smooth', block: 'center' });
            
            // Simulate AI Enhancement
            await simulateEnhancement(prompt);
            
            // Simulate generation steps
            await runGenerationSteps();
            
            // Show video player
            document.getElementById('video-section').classList.remove('hidden');
            document.getElementById('video-section').scrollIntoView({ behavior: 'smooth', block: 'center' });
            
            // Reset button
            btn.innerHTML = originalText;
            btn.disabled = false;
        }
        
        async function simulateEnhancement(prompt) {
            const badge = document.getElementById('ai-enhance-badge');
            const preview = document.getElementById('enhanced-preview');
            const enhancedText = document.getElementById('enhanced-text');
            
            badge.classList.remove('hidden');
            badge.classList.add('flex');
            
            // Simulate AI thinking
            await sleep(1500);
            
            // Generate enhanced script based on prompt
            const enhanced = generateEnhancedScript(prompt);
            enhancedText.textContent = enhanced;
            
            badge.classList.add('hidden');
            badge.classList.remove('flex');
            preview.classList.remove('hidden');
        }
        
        function generateEnhancedScript(prompt) {
            const isSinhala = /[\u0D80-\u0DFF]/.test(prompt);
            
            if (isSinhala) {
                return `[ENHANCED CINEMATIC SCRIPT]\n\nOriginal: "${prompt}"\n\nExpanded: A cinematic journey beginning with aerial drone shots of mist-covered mountains at golden hour (0:00-0:30). Transition to intimate close-ups of traditional hands performing ancient rituals (0:30-1:15). Emotional arc builds with orchestral strings and ambient temple bells. Voiceover in natural Sinhala female tone with reverent emotion. Auto-selected color grading: warm amber tones with teal shadows. Camera movements: slow dolly zooms and gentle tracking shots. Background score adapts to contemplative mood with 432Hz tuning...`;
            }
            
            return `[ENHANCED CINEMATIC SCRIPT]\n\nOriginal: "${prompt}"\n\nExpanded: Opening with cinematic wide establishing shot of ancient temple architecture at 5:30 AM sunrise (0:00-0:45). Slow-motion particles of incense smoke catching golden light rays. Transition to intimate POV walking through stone corridors with ambient reverb (0:45-2:00). AI-selected color palette: warm golds, deep saffron oranges, cool stone grays. Camera angles: low-angle hero shots intercut with intimate macro details. Background score: ambient orchestral with traditional flute melodies. Voiceover: Natural Sinhala female, calm and meditative tone with precise lip-sync...`;
        }
        
        async function runGenerationSteps() {
            const steps = document.querySelectorAll('.step-item');
            const progressCircle = document.getElementById('progress-circle');
            const progressText = document.getElementById('progress-text');
            const circumference = 264;
            
            for (let i = 0; i < steps.length; i++) {
                const step = steps[i];
                const status = step.querySelector('.step-status');
                
                // Activate step
                step.classList.remove('opacity-50');
                step.classList.add('opacity-100', 'bg-white/10', 'border-indigo-500/30');
                status.classList.remove('bg-gray-600');
                status.classList.add('bg-indigo-500', 'animate-pulse');
                
                // Update progress
                const progress = ((i + 1) / steps.length) * 100;
                const offset = circumference - (progress / 100) * circumference;
                progressCircle.style.strokeDashoffset = offset;
                progressText.textContent = Math.round(progress) + '%';
                
                // If step 2, show scene previews
                if (i === 1) {
                    await generateScenePreviews();
                }
                
                await sleep(2000);
                
                // Complete step
                status.classList.remove('bg-indigo-500', 'animate-pulse');
                status.classList.add('bg-green-500');
                step.querySelector('.w-8').innerHTML = '<svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>';
            }
            
            // Final completion
            progressText.textContent = '100%';
            await sleep(500);
        }
        
        async function generateScenePreviews() {
            const container = document.getElementById('scene-preview');
            container.classList.remove('hidden');
            
            const scenes = [
                { title: 'Scene 1: Establishing', desc: 'Aerial sunrise', color: 'from-orange-400/20 to-purple-500/20' },
                { title: 'Scene 2: Intimate', desc: 'Close-up rituals', color: 'from-amber-400/20 to-orange-500/20' },
                { title: 'Scene 3: Transition', desc: 'Corridor walk', color: 'from-blue-400/20 to-indigo-500/20' },
                { title: 'Scene 4: Climax', desc: 'Temple reveal', color: 'from-purple-400/20 to-pink-500/20' }
            ];
            
            scenes.forEach((scene, index) => {
                setTimeout(() => {
                    const div = document.createElement('div');
                    div.className = 'scene-card glass rounded-lg p-4 border border-white/10';
                    div.innerHTML = `
                        <div class="aspect-video rounded-md bg-gradient-to-br ${scene.color} mb-3 flex items-center justify-center">
                            <span class="text-2xl">🎬</span>
                        </div>
                        <h5 class="font-medium text-sm mb-1">${scene.title}</h5>
                        <p class="text-xs text-gray-500">${scene.desc}</p>
                        <div class="mt-2 flex items-center gap-1">
                            <span class="text-[10px] px-2 py-0.5 rounded bg-white/10 text-gray-400">AI Camera</span>
                            <span class="text-[10px] px-2 py-0.5 rounded bg-white/10 text-gray-400">Auto-cut</span>
                        </div>
                    `;
                    container.appendChild(div);
                }, index * 300);
            });
        }
        
        function sleep(ms) {
            return new Promise(resolve => setTimeout(resolve, ms));
        }
        
        // Video Player Functions
        let isPlaying = false;
        let progressInterval;
        
        function playVideo() {
            const overlay = document.getElementById('video-overlay');
            const content = document.getElementById('video-content');
            const progressBar = document.getElementById('progress-bar');
            
            if (!isPlaying) {
                isPlaying = true;
                overlay.style.opacity = '1';
                content.style.opacity = '0';
                
                // Simulate progress
                let progress = 0;
                progressInterval = setInterval(() => {
                    progress += 0.5;
                    progressBar.style.width = progress + '%';
                    
                    // Show subtitles at certain points
                    if (progress > 20 && progress < 80) {
                        document.getElementById('subtitle-preview').classList.remove('hidden');
                    } else {
                        document.getElementById('subtitle-preview').classList.add('hidden');
                    }
                    
                    if (progress >= 100) {
                        progress = 0;
                    }
                }, 100);
            } else {
                isPlaying = false;
                overlay.style.opacity = '0';
                content.style.opacity = '1';
                clearInterval(progressInterval);
            }
        }
        
        function toggleSubtitles() {
            const btn = document.getElementById('sub-btn');
            if (btn.textContent === 'ON') {
                btn.textContent = 'OFF';
                btn.classList.remove('bg-green-500/20', 'text-green-400', 'border-green-500/30');
                btn.classList.add('bg-red-500/20', 'text-red-400', 'border-red-500/30');
            } else {
                btn.textContent = 'ON';
                btn.classList.remove('bg-red-500/20', 'text-red-400', 'border-red-500/30');
                btn.classList.add('bg-green-500/20', 'text-green-400', 'border-green-500/30');
            }
        }
        
        function exportVideo(format) {
            const btn = event.currentTarget;
            const originalText = btn.innerHTML;
            btn.innerHTML = '<svg class="w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg><span>Exporting...</span>';
            
            setTimeout(() => {
                btn.innerHTML = '<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg><span>Done!</span>';
                setTimeout(() => {
                    btn.innerHTML = originalText;
                }, 2000);
            }, 2000);
        }
        
        // Auto-detect Sinhala input
        document.getElementById('prompt-input').addEventListener('input', function(e) {
            const value = e.target.value;
            const voiceSelect = document.getElementById('voice-select');
            
            if (/[\u0D80-\u0DFF]/.test(value) && voiceSelect.value === 'auto') {
                voiceSelect.value = 'sinhala-female';
                // Visual feedback
                voiceSelect.classList.add('border-cyan-500');
                setTimeout(() => voiceSelect.classList.remove('border-cyan-500'), 1000);
            }
        });
    </script>
</body>
